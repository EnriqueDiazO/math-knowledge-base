{
  "name": "@mathmongo/advanced-reader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "prepare:worker": "node scripts/prepare-pdf-worker.mjs",
    "predev": "npm run prepare:worker",
    "dev": "vite --host 127.0.0.1",
    "pretypecheck": "npm run prepare:worker",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node tests/e2e-runner.mjs",
    "test:e2e:runner": "node tests/e2e-runner.mjs",
    "prebuild": "npm run prepare:worker",
    "build": "tsc -b && vite build && node scripts/publish-build.mjs",
    "publish": "node scripts/publish-build.mjs"
  },
  "dependencies": {
    "pdfjs-dist": "6.1.200",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}
